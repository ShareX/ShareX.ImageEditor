<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="320"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.CrosshatchDialog"
             x:Name="CrosshatchDialogRoot">

    <StackPanel Spacing="0">
        <TextBlock Text="Crosshatch" Margin="0,0,0,8"/>

        <StackPanel Spacing="8">
            <controls:EffectSlider Label="Line spacing (px)" ValueStringFormat="{}{0:0}" x:Name="SpacingSlider"
                                   Minimum="4"
                                   Maximum="24"
                                   Value="8"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Line thickness (px)" ValueStringFormat="{}{0:0.0}" x:Name="ThicknessSlider"
                                   Minimum="0.5"
                                   Maximum="4"
                                   Value="1.2"
                                   TickFrequency="0.1"
                                   IsSnapToTickEnabled="False"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Contrast (%)" ValueStringFormat="{}{0:0}" x:Name="ContrastSlider"
                                   Minimum="50"
                                   Maximum="200"
                                   Value="120"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Layers" ValueStringFormat="{}{0:0}" x:Name="LayerSlider"
                                   Minimum="1"
                                   Maximum="6"
                                   Value="4"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
