<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="380"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.BevelDialog">

    <StackPanel Spacing="0">
        <TextBlock Text="Bevel" Margin="0,0,0,8"/>

        <StackPanel Spacing="10">
            <controls:EffectSlider Label="Size" ValueStringFormat="{}{0:0}" x:Name="SizeSlider"
                                   Minimum="1"
                                   Maximum="40"
                                   Value="10"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Strength (%)" ValueStringFormat="{}{0:0}" x:Name="StrengthSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="70"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Light angle" ValueStringFormat="{}{0:0}°" x:Name="AngleSlider"
                                   Minimum="0"
                                   Maximum="360"
                                   Value="225"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <StackPanel Spacing="4">
                <TextBlock Text="Highlight color"/>
                <controls:ColorPickerDropdown x:Name="HighlightColorPicker"
                                              SelectedColorValue="#D9FFFFFF"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Shadow color"/>
                <controls:ColorPickerDropdown x:Name="ShadowColorPicker"
                                              SelectedColorValue="#B0000000"/>
            </StackPanel>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button"
                    Content="Cancel"
                    Click="OnCancelClick"
                    Margin="0,0,4,0"
                    HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active"
                    Content="Apply"
                    Click="OnApplyClick"
                    Margin="4,0,0,0"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
