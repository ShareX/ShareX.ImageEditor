<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="420"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.ASCIIArtDialog"
             x:Name="ASCIIArtDialogRoot">

    <StackPanel Spacing="0">
        <TextBlock Text="ASCII Art" Margin="0,0,0,8"/>

        <StackPanel Spacing="10">
            <controls:EffectSlider Label="Character size (px)" ValueStringFormat="{}{0:0}" x:Name="CellSizeSlider"
                                   Minimum="4"
                                   Maximum="24"
                                   Value="8"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Contrast (%)" ValueStringFormat="{}{0:0}" x:Name="ContrastSlider"
                                   Minimum="50"
                                   Maximum="200"
                                   Value="110"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <StackPanel Spacing="4">
                <TextBlock Text="Character set"/>
                <TextBox x:Name="CharacterSetTextBox"
                         Text="@%#*+=-:. "
                         TextChanged="OnTextChanged"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="16">
                <CheckBox x:Name="InvertCheckBox" Content="Invert luminance" Foreground="#E7E9EA"
                          Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
                <CheckBox x:Name="DarkBackgroundCheckBox" Content="Dark background" Foreground="#E7E9EA"
                          IsChecked="True"
                          Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
            </StackPanel>

            <CheckBox x:Name="UseSourceColorCheckBox" Content="Use source colors" Foreground="#E7E9EA"
                      IsChecked="True"
                      Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
