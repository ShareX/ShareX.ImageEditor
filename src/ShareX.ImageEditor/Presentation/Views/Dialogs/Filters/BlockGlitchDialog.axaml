<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="520"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.BlockGlitchDialog"
             x:Name="BlockGlitchDialogRoot">

    <StackPanel Spacing="0">
        <TextBlock Text="Block Glitch / Databending" Margin="0,0,0,8"/>

        <StackPanel Spacing="8">
            <controls:EffectSlider Label="Block count" ValueStringFormat="{}{0:0}" x:Name="BlockCountSlider"
                                   Minimum="1"
                                   Maximum="240"
                                   Value="36"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Min block width (px)" ValueStringFormat="{}{0:0}" x:Name="MinWidthSlider"
                                   Minimum="4"
                                   Maximum="400"
                                   Value="24"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Max block width (px)" ValueStringFormat="{}{0:0}" x:Name="MaxWidthSlider"
                                   Minimum="4"
                                   Maximum="900"
                                   Value="200"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Min block height (px)" ValueStringFormat="{}{0:0}" x:Name="MinHeightSlider"
                                   Minimum="2"
                                   Maximum="200"
                                   Value="6"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Max block height (px)" ValueStringFormat="{}{0:0}" x:Name="MaxHeightSlider"
                                   Minimum="2"
                                   Maximum="500"
                                   Value="50"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Max displacement (px)" ValueStringFormat="{}{0:0}" x:Name="DisplacementSlider"
                                   Minimum="0"
                                   Maximum="500"
                                   Value="50"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Channel shift (px)" ValueStringFormat="{}{0:0}" x:Name="ChannelShiftSlider"
                                   Minimum="0"
                                   Maximum="64"
                                   Value="4"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Noise (%)" ValueStringFormat="{}{0:0}" x:Name="NoiseSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="10"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
