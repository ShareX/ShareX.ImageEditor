<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="260"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.ChromaticAberrationDialog"
             x:Name="ChromaticAberrationDialogRoot">

    <StackPanel Spacing="0">
        <TextBlock Text="Chromatic Aberration" Margin="0,0,0,8"/>

        <StackPanel Spacing="8">
            <controls:EffectSlider Label="Amount (px)" ValueStringFormat="{}{0:0}" x:Name="AmountSlider"
                                   Minimum="0"
                                   Maximum="40"
                                   Value="8"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Coverage (%)" ValueStringFormat="{}{0:0}" x:Name="CoverageSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="80"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Strength (%)" ValueStringFormat="{}{0:0}" x:Name="StrengthSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="75"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
