<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Controls"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="470"
             x:Class="ShareX.ImageEditor.Views.Dialogs.PixelSortingDialog"
             x:Name="PixelSortingDialogRoot">

    <StackPanel Spacing="0">
        <TextBlock Text="Pixel Sorting" Foreground="#9CA3AF" Margin="0,0,0,8"/>

        <StackPanel Spacing="10">
            <StackPanel Spacing="4">
                <TextBlock Text="Direction" Foreground="#9CA3AF"/>
                <ComboBox x:Name="DirectionComboBox"
                          SelectedIndex="1"
                          SelectionChanged="OnSelectionChanged"
                          HorizontalAlignment="Stretch"
                          Background="#374151"
                          BorderThickness="0"
                          CornerRadius="4">
                    <ComboBoxItem Content="Horizontal"/>
                    <ComboBoxItem Content="Vertical"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Sort by" Foreground="#9CA3AF"/>
                <ComboBox x:Name="MetricComboBox"
                          SelectedIndex="0"
                          SelectionChanged="OnSelectionChanged"
                          HorizontalAlignment="Stretch"
                          Background="#374151"
                          BorderThickness="0"
                          CornerRadius="4">
                    <ComboBoxItem Content="Brightness"/>
                    <ComboBoxItem Content="Hue"/>
                </ComboBox>
            </StackPanel>

            <controls:EffectSlider Label="Threshold low (%)" ValueStringFormat="{}{0:0}" x:Name="ThresholdLowSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="12"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Threshold high (%)" ValueStringFormat="{}{0:0}" x:Name="ThresholdHighSlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="85"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Minimum span (px)" ValueStringFormat="{}{0:0}" x:Name="MinSpanSlider"
                                   Minimum="2"
                                   Maximum="256"
                                   Value="8"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Maximum span (px)" ValueStringFormat="{}{0:0}" x:Name="MaxSpanSlider"
                                   Minimum="2"
                                   Maximum="512"
                                   Value="120"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>

            <controls:EffectSlider Label="Sort probability (%)" ValueStringFormat="{}{0:0}" x:Name="ProbabilitySlider"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="85"
                                   TickFrequency="1"
                                   IsSnapToTickEnabled="True"
                                   ValueChanged="OnValueChanged"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
