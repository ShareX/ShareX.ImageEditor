<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="250"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.RoundedCornersDialog"
             x:Name="RoundedCornersDialogRoot">

    <StackPanel Spacing="0">
        <!-- Header -->
        <TextBlock Text="Rounded Corners" Margin="0,0,0,8"/>
        
        <!-- Slider -->
        <controls:EffectSlider Label="Corner Radius" ValueStringFormat="{}{0:0} px" x:Name="RadiusSlider"
                    Minimum="0" Maximum="500" Value="20"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                   
                    ValueChanged="OnValueChanged"/>

        <!-- Buttons -->
        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button" Content="Cancel" Click="OnCancelClick" Margin="0,0,4,0" HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active" Content="Apply" Click="OnApplyClick" Margin="4,0,0,0" Grid.Column="1" HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>

