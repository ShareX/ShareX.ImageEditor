<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:ShareX.ImageEditor.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="760"
             x:Class="ShareX.ImageEditor.Presentation.Views.Dialogs.TextWatermarkDialog">

    <StackPanel Spacing="0">
        <TextBlock Text="Text watermark" Margin="0,0,0,8"/>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <StackPanel Spacing="4">
                    <TextBlock Text="Text"/>
                    <TextBox x:Name="TextContentInput"
                             Text="Text watermark"
                             TextChanged="OnTextChanged"
                             AcceptsReturn="True"
                             MinHeight="70"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Placement"/>
                    <ComboBox x:Name="PlacementComboBox"
                              SelectedIndex="8"
                              SelectionChanged="OnSelectionChanged"
                              HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Top left"/>
                        <ComboBoxItem Content="Top center"/>
                        <ComboBoxItem Content="Top right"/>
                        <ComboBoxItem Content="Middle left"/>
                        <ComboBoxItem Content="Middle center"/>
                        <ComboBoxItem Content="Middle right"/>
                        <ComboBoxItem Content="Bottom left"/>
                        <ComboBoxItem Content="Bottom center"/>
                        <ComboBoxItem Content="Bottom right"/>
                    </ComboBox>
                </StackPanel>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Offset X"/>
                        <NumericUpDown x:Name="OffsetXInput"
                                       Value="5"
                                       Minimum="-4000"
                                       Maximum="4000"
                                       Increment="1"
                                       FormatString="0"
                                       ValueChanged="OnNumericChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Offset Y"/>
                        <NumericUpDown x:Name="OffsetYInput"
                                       Value="5"
                                       Minimum="-4000"
                                       Maximum="4000"
                                       Increment="1"
                                       FormatString="0"
                                       ValueChanged="OnNumericChanged"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Font size"/>
                        <NumericUpDown x:Name="FontSizeInput"
                                       Value="15"
                                       Minimum="1"
                                       Maximum="500"
                                       Increment="1"
                                       FormatString="0"
                                       ValueChanged="OnNumericChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Corner radius"/>
                        <NumericUpDown x:Name="CornerRadiusInput"
                                       Value="4"
                                       Minimum="0"
                                       Maximum="500"
                                       Increment="1"
                                       FormatString="0"
                                       ValueChanged="OnNumericChanged"/>
                    </StackPanel>
                </Grid>

                <StackPanel Spacing="4">
                    <TextBlock Text="Font family"/>
                    <TextBox x:Name="FontFamilyTextBox"
                             Text="Arial"
                             TextChanged="OnTextChanged"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="16">
                    <CheckBox x:Name="BoldCheckBox"
                              Content="Bold"
                              Foreground="#E7E9EA"
                              Checked="OnSettingChanged"
                              Unchecked="OnSettingChanged"/>
                    <CheckBox x:Name="ItalicCheckBox"
                              Content="Italic"
                              Foreground="#E7E9EA"
                              Checked="OnSettingChanged"
                              Unchecked="OnSettingChanged"/>
                    <CheckBox x:Name="AutoHideCheckBox"
                              Content="Auto hide"
                              Foreground="#E7E9EA"
                              Checked="OnSettingChanged"
                              Unchecked="OnSettingChanged"/>
                </StackPanel>

                <Separator/>
                <TextBlock Text="Padding"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Left"/>
                        <NumericUpDown x:Name="PaddingLeftInput"
                                       Value="5"
                                       Minimum="0"
                                       Maximum="500"
                                       Increment="1"
                                       FormatString="0"
                                       ValueChanged="OnNumericChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Top"/>
                        <NumericUpDown x:Name="PaddingTopInput"
                                       Value="5"
                                       Minimum="0"
                                       Maximum="500"
                                       Increment="1"
                                       FormatString="0"
                                       ValueChanged="OnNumericChanged"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Right"/>
                        <NumericUpDown x:Name="PaddingRightInput"
                                       Value="5"
                                       Minimum="0"
                                       Maximum="500"
                                       Increment="1"
                                       FormatString="0"
                                       ValueChanged="OnNumericChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Bottom"/>
                        <NumericUpDown x:Name="PaddingBottomInput"
                                       Value="5"
                                       Minimum="0"
                                       Maximum="500"
                                       Increment="1"
                                       FormatString="0"
                                       ValueChanged="OnNumericChanged"/>
                    </StackPanel>
                </Grid>

                <Separator/>
                <TextBlock Text="Text"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="Color"/>
                    <controls:ColorPickerDropdown x:Name="TextColorPicker"
                                                  SelectedColorValue="#FFEBEBEB"/>
                </StackPanel>

                <Separator/>
                <TextBlock Text="Background"/>

                <CheckBox x:Name="BackgroundCheckBox"
                          Content="Enable background"
                          IsChecked="True"
                          Foreground="#E7E9EA"
                          Checked="OnSettingChanged"
                          Unchecked="OnSettingChanged"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="Background color"/>
                    <controls:ColorPickerDropdown x:Name="BackgroundColorPicker"
                                                  SelectedColorValue="#FF2A2F38"/>
                </StackPanel>

                <Separator/>
                <TextBlock Text="Border"/>

                <CheckBox x:Name="BorderCheckBox"
                          Content="Enable border"
                          IsChecked="True"
                          Foreground="#E7E9EA"
                          Checked="OnSettingChanged"
                          Unchecked="OnSettingChanged"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Border size"/>
                        <NumericUpDown x:Name="BorderSizeInput"
                                       Value="1"
                                       Minimum="0"
                                       Maximum="200"
                                       Increment="1"
                                       FormatString="0"
                                       ValueChanged="OnNumericChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Border color"/>
                        <controls:ColorPickerDropdown x:Name="BorderColorPicker"
                                                      SelectedColorValue="#FF000000"/>
                    </StackPanel>
                </Grid>

                <Separator/>
                <TextBlock Text="Shadow"/>

                <CheckBox x:Name="ShadowCheckBox"
                          Content="Enable shadow"
                          Foreground="#E7E9EA"
                          Checked="OnSettingChanged"
                          Unchecked="OnSettingChanged"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Shadow offset X"/>
                        <NumericUpDown x:Name="ShadowOffsetXInput"
                                       Value="-1"
                                       Minimum="-4000"
                                       Maximum="4000"
                                       Increment="1"
                                       FormatString="0"
                                       ValueChanged="OnNumericChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Shadow offset Y"/>
                        <NumericUpDown x:Name="ShadowOffsetYInput"
                                       Value="-1"
                                       Minimum="-4000"
                                       Maximum="4000"
                                       Increment="1"
                                       FormatString="0"
                                       ValueChanged="OnNumericChanged"/>
                    </StackPanel>
                </Grid>

                <StackPanel Spacing="4">
                    <TextBlock Text="Shadow color"/>
                    <controls:ColorPickerDropdown x:Name="ShadowColorPicker"
                                                  SelectedColorValue="#FF000000"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
            <Button Classes="editor-button"
                    Content="Cancel"
                    Click="OnCancelClick"
                    Margin="0,0,4,0"
                    HorizontalAlignment="Stretch"/>
            <Button Classes="editor-button active"
                    Content="Apply"
                    Click="OnApplyClick"
                    Margin="4,0,0,0"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"/>
        </Grid>
    </StackPanel>
</UserControl>
