<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ShareX.ImageEditor.Presentation.ViewModels;assembly=ShareX.ImageEditor"
             x:Class="ShareX.ImageEditor.Presentation.Controls.ToolInfoPanel"
             x:DataType="vm:ToolInfoModel">

    <!-- Compact horizontal info panel: icon + title + relevant summary chips -->
    <StackPanel Orientation="Horizontal"
                Spacing="5"
                VerticalAlignment="Center"
                Height="40"
                Opacity="0.75">

        <!-- Tool icon -->
        <TextBlock Text="{Binding Icon}"
                   FontFamily="{DynamicResource ShareX.FontFamily.Icon}"
                   FontSize="14"
                   FontWeight="Normal"
                   Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Margin="2,0,0,0"/>

        <!-- Tool title -->
        <TextBlock Text="{Binding Title}"
                   FontSize="11"
                   FontWeight="Normal"
                   Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                   VerticalAlignment="Center"/>

        <!-- Primary color chip -->
        <Border Width="10" Height="10" CornerRadius="2"
                VerticalAlignment="Center"
                BorderBrush="{DynamicResource ShareX.Brush.Border}"
                BorderThickness="0.5"
                IsVisible="{Binding ShowPrimaryColor}">
            <Border.Background>
                <SolidColorBrush Color="{Binding PrimaryColor}"/>
            </Border.Background>
        </Border>

        <!-- Secondary (fill) color chip -->
        <Border Width="10" Height="10" CornerRadius="2"
                VerticalAlignment="Center"
                BorderBrush="{DynamicResource ShareX.Brush.Border}"
                BorderThickness="0.5"
                IsVisible="{Binding ShowSecondaryColor}">
            <Border.Background>
                <SolidColorBrush Color="{Binding SecondaryColor}"/>
            </Border.Background>
        </Border>

        <!-- Text color chip -->
        <TextBlock Text="A"
                   FontSize="11"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   IsVisible="{Binding ShowTextColor}">
            <TextBlock.Foreground>
                <SolidColorBrush Color="{Binding TextColor}"/>
            </TextBlock.Foreground>
        </TextBlock>

        <!-- Thickness chip -->
        <TextBlock IsVisible="{Binding ShowThickness}"
                   FontSize="11"
                   Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                   VerticalAlignment="Center">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}{0}px">
                    <Binding Path="Thickness"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <!-- Font size chip -->
        <TextBlock IsVisible="{Binding ShowFontSize}"
                   FontSize="11"
                   Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                   VerticalAlignment="Center">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}{0:0}pt">
                    <Binding Path="FontSize"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <!-- Text style summary (B I U) -->
        <StackPanel Orientation="Horizontal"
                    Spacing="2"
                    VerticalAlignment="Center"
                    IsVisible="{Binding ShowTextStyle}">
            <TextBlock Text="B" FontSize="11" FontWeight="Bold" Opacity="0.4"
                       Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                       VerticalAlignment="Center">
                <TextBlock.IsVisible>
                    <Binding Path="IsBold"/>
                </TextBlock.IsVisible>
            </TextBlock>
            <TextBlock Text="I" FontSize="11" FontStyle="Italic" Opacity="0.4"
                       Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                       VerticalAlignment="Center">
                <TextBlock.IsVisible>
                    <Binding Path="IsItalic"/>
                </TextBlock.IsVisible>
            </TextBlock>
            <TextBlock Text="U" FontSize="11" Opacity="0.4"
                       Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                       VerticalAlignment="Center"
                       TextDecorations="Underline">
                <TextBlock.IsVisible>
                    <Binding Path="IsUnderline"/>
                </TextBlock.IsVisible>
            </TextBlock>
        </StackPanel>

        <!-- Strength chip -->
        <TextBlock IsVisible="{Binding ShowStrength}"
                   FontSize="11"
                   Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                   VerticalAlignment="Center">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}str {0:0}">
                    <Binding Path="Strength"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <!-- Dimensions chip -->
        <TextBlock IsVisible="{Binding ShowDimensions}"
                   FontSize="11"
                   Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                   VerticalAlignment="Center"
                   Opacity="0.85">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}{0:0} x {1:0}">
                    <Binding Path="InfoWidth"/>
                    <Binding Path="InfoHeight"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>
    </StackPanel>
</UserControl>
